# Run artifacts (contain client data — never commit)
**/runs/
**/run/
**/.runs/

# Claude Code local state (but NOT .claude/agents/ or .claude/skills/ — those are skill content)
**/.claude/scheduled_tasks.lock
**/.claude/worktrees/
**/.claude/settings.local.json
**/.claude/.env
**/.claude/skills/*/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo

# Secrets — never commit
.env
.env.*
*.key
*.pem
credentials.json
secrets.json

# Build / temp
*.log
*.tmp
*.bak
dist/
build/
